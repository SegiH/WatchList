{
  "name": "reactwebpacktemplate",
  "version": "1.0.0",
  "description": "WatchList application is a multi-user app that lets you track the movies and TV that you watch, how many times you watched them and when you watched them. You can also rate movies or shows.",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "webpack --mode production && ./fix-bundle-path.sh",
    "build-win": "webpack --mode production && copy electron-package.json dist\\package.json",
    "build-linux": "webpack --mode production && cp electron-package.json dist/package.json",
    "build-mac": "webpack --mode production && cp electron-package.json dist/package.json",
    "serve": "webpack serve --mode development",
    "dev": "webpack serve --config ./src/index.js",
    "start": "webpack --mode development",
    "prettier": "npx prettier --write src/*.js && npx prettier --write src/**/*.js && npx prettier --write src/**/**/*.js",
    "dev:electron": "webpack --config webpack.electron.config.js --mode development && electron ./dist/electron-app.js --dev",
    "build:electron": "webpack --config webpack.electron.config.js",
    "deploy-win": "electron-packager ./dist watchlist --overwrite --platform=win32 --arch=x64 --prune=true --out=release-builds",
    "deploy-linux": "electron-packager ./dist watchlist --overwrite --platform=linux --arch=x64 --prune=true --out=release-builds",
    "deploy-mac": "electron-packager ./dist watchlist --overwrite --platform=darwin --arch=x64 --prune=true --out=release-builds",
    "electron": "npm run build && npm run build:electron && npm run deploy"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@babel/preset-env": "^7.21.5",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.1",
    "@mui/lab": "^5.0.0-alpha.141",
    "@mui/material": "^5.14.3",
    "@mui/x-data-grid": "^6.11.0",
    "@mui/x-data-grid-pro": "^6.11.0",
    "@types/electron": "^1.6.10",
    "axios": "^1.3.3",
    "dotenv-webpack": "^8.0.1",
    "electron": "^25.4.0",
    "electron-packager": "^17.1.1",
    "html-webpack-plugin": "^5.5.3",
    "prop-types": "^15.8.1",
    "prop-types-exact": "^1.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-react": "^7.18.6",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "babel-loader": "^9.1.2",
    "css-loader": "^6.7.3",
    "eslint": "^8.48.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-config-standard-with-typescript": "^39.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-n": "^16.0.2",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.33.2",
    "file-loader": "^6.2.0",
    "prettier": "^3.0.0",
    "style-loader": "^3.3.1",
    "ts-loader": "^9.4.4",
    "typescript": "^5.2.2",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
